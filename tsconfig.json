{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "types": ["node", "jest"]
  },
  "include": [
    "admin-function/index.ts",
    "admin-function/registers.ts",
    "proxies",
    "use-cases",
    "__tests__"
  ],
  "exclude": ["node_modules", "dist"]
}
